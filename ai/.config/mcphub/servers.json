{
  "mcpServers": {
    "figma": {
      "tools": ["*"],
      "command": "npx",
      "args": [
        "-y",
        "figma-developer-mcp",
        "--figma-api-key=${FIGMA_API_KEY}",
        "--stdio"
      ],
      "env": {
        "FIGMA_API_KEY": "${FIGMA_API_KEY}"
      },
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "git": {
      "tools": ["*"],
      "type": "local",
      "command": "mcp-server-git",
      "args": [],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "gitnexus": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["-y", "gitnexus", "mcp"],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "memory": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "playwright": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "postman-api-mcp": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["@postman/postman-mcp-server", "--full"],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      },
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "local_figma": {
      "type": "http",
      "url": "http://127.0.0.1:3845/mcp",
      "headers": {},
      "tools": ["*"]
    }
  },
  "nativeMCPServers": []
}
