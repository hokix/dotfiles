{
  "mcpServers": {
    "git": {
      "tools": ["*"],
      "type": "local",
      "command": "mcp-server-git",
      "args": [],
      "source": "user"
    },
    "memory": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "source": "user"
    },
    "playwright": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "source": "user"
    },
    "postman-api-mcp": {
      "tools": ["*"],
      "type": "local",
      "command": "npx",
      "args": ["@postman/postman-mcp-server", "--full"],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      },
      "source": "user"
    }
  },
  "nativeMCPServers": []
}
