{
  "mcpServers": {
    "browsermcp": {
      "args": ["@browsermcp/mcp@latest"],
      "command": "npx",
      "tools": ["*"],
      "type": "local"
    },
    "carnival": {
      "args": [],
      "command": "carnival-mcp",
      "tools": ["*"],
      "type": "local"
    },
    "git": {
      "args": [],
      "command": "mcp-server-git",
      "tools": ["*"],
      "type": "local"
    },
    "memory": {
      "args": ["-y", "@modelcontextprotocol/server-memory"],
      "command": "npx",
      "tools": ["*"],
      "type": "local"
    },
    "playwright": {
      "args": ["@playwright/mcp@latest"],
      "command": "npx",
      "tools": ["*"],
      "type": "local"
    },
    "postman-api-mcp": {
      "args": ["@postman/postman-mcp-server", "--full"],
      "command": "npx",
      "disabled": false,
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      },
      "tools": ["*"],
      "type": "local"
    },
    "sequentialthinking": {
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"],
      "command": "npx",
      "tools": ["*"],
      "type": "local"
    }
  },
  "nativeMCPServers": []
}
