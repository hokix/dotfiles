{
  "mcpServers": {
    "browsermcp": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "@browsermcp/mcp@latest"
      ],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "git": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "mcp-server-git",
      "args": [],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "memory": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "playwright": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "postman-api-mcp": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "@postman/postman-mcp-server",
        "--full"
      ],
      "env": {
        "POSTMAN_API_KEY": "${POSTMAN_API_KEY}"
      },
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    },
    "sequentialthinking": {
      "tools": [
        "*"
      ],
      "type": "local",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "source": "user",
      "sourcePath": "/Users/ted/.copilot/mcp-config.json"
    }
  },
  "nativeMCPServers": []
}
