{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "@zenobius/opencode-skillful",
    "oh-my-opencode",
    "@tarquinen/opencode-dcp@latest"
  ],
  "mcp": {
    "browsermcp": {
      "command": ["npx", "@browsermcp/mcp@latest"],
      "type": "local"
    },
    "git": {
      "command": ["mcp-server-git"],
      "type": "local"
    },
    "memory": {
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "@playwright/mcp@latest"],
      "type": "local"
    },
    "postman-api-mcp": {
      "command": ["npx", "@postman/postman-mcp-server", "--full"],
      "environment": {
        "POSTMAN_API_KEY": "{env:POSTMAN_API_KEY}"
      },
      "type": "local"
    },
    "gitnexus": {
      "command": ["npx", "-y", "gitnexus", "mcp"],
      "type": "local"
    }
  }
}
