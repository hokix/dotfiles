{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["oh-my-openagent@latest"],
  "mcp": {
    "browsermcp": {
      "command": ["npx", "@browsermcp/mcp@latest"],
      "type": "local"
    },
    "git": {
      "command": ["mcp-server-git"],
      "type": "local"
    },
    "memory": {
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "type": "local"
    },
    "playwright": {
      "command": ["npx", "@playwright/mcp@latest"],
      "type": "local"
    },
    "postman-api-mcp": {
      "command": ["npx", "@postman/postman-mcp-server", "--full"],
      "environment": {
        "POSTMAN_API_KEY": "{env:POSTMAN_API_KEY}"
      },
      "type": "local"
    },
    "local_figma": {
      "type": "remote",
      "url": "http://127.0.0.1:3845/mcp",
      "headers": {}
    }
  },
  "provider": {
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek",
      "options": {
        "baseURL": "https://api.deepseek.com"
      },
      "models": {
        "deepseek-v4-flash": {
          "name": "DeepSeek-V4-Flash",
          "limit": {
            "context": 1048576,
            "output": 393216
          },
          "options": {
            "reasoningEffort": "high",
            "thinking": {
              "type": "enabled"
            }
          }
        },
        "deepseek-v4-pro": {
          "name": "DeepSeek-V4-Pro",
          "limit": {
            "context": 1048576,
            "output": 393216
          },
          "options": {
            "reasoningEffort": "max",
            "thinking": {
              "type": "enabled"
            }
          }
        }
      }
    }
  }
}
