[user]
    email = hokix@live.com
    name = hokix
[core]
    excludesfile = ~/.gitignore
    pager = less -FRX
[commit]
    template = ~/.gittemplate
    verbose = true
[push]
    default = simple
    autoSetupRemote = true
[pull]
    default = simple
    rebase = true
[color]
    ui = auto
[merge]
    tool = nvimdiff
[diff]
    tool = nvimdiff
[format]
    pretty = format:'%Cred%h%Creset -%C(yellow)%d%Creset %an %s %Cgreen(%ad)%Creset'
; [url "git@github.com:"]
;     insteadOf = http://github.com/
; [url "git@github.com:"]
;     insteadOf = https://github.com/
; [url "https://github.com/"]
;     insteadOf = git@github.com:
[include]
    path = .gitconfig-url
    path = .gitconfig-local
[includeIf "gitdir:~/workspace*/"]
    path = .gitconfig-job
[credential "https://github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://gist.github.com"]
	helper = 
	helper = !/opt/homebrew/bin/gh auth git-credential
[credential "https://dev.azure.com"]
	useHttpPath = true
[url "ssh://git@git.dz11.com/"]
	insteadOf = https://git.dz11.com/
